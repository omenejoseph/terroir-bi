APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Base URL of the decoupled Next.js frontend (no trailing slash). Used to build
# return URLs for external flows (e.g. Stripe Checkout success/cancel).
FRONTEND_URL=http://localhost:3000

# Public base URL of THIS backend, used by ./deploy-frontend.sh to bake the
# frontend's NEXT_PUBLIC_API_URL ("${REMOTE_BACKEND_URL}/api/v1") into the
# Cloudflare build. Required to deploy; the script errors if it's empty.
REMOTE_BACKEND_URL=https://api.your-domain.com

APP_LOCALE=hr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Tenancy (abstraction layer — see config/tenant.php)
TENANT_DRIVER=stancl
TENANT_DEFAULT_ISOLATION=shared_row
TENANT_CENTRAL_DOMAINS=127.0.0.1,localhost

# Money (see config/money.php)
MONEY_DEFAULT_CURRENCY=EUR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Uploads store. Defaults to Cloudflare R2 (the 'r2' disk below).
# Set to 'uploads' to use the generic S3 disk (UPLOADS_S3_* / AWS_*) instead.
UPLOADS_DISK=r2
UPLOADS_UPLOAD_TTL=300
UPLOADS_READ_TTL=900

# Cloudflare R2 (default uploads store; private bucket, presigned access).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_DEFAULT_REGION=auto
R2_BUCKET=reserve
R2_URL=
R2_ENDPOINT=https://f34bece59f1349f5512c901d1427e219.r2.cloudflarestorage.com
R2_USE_PATH_STYLE_ENDPOINT=false

# Generic S3 uploads bucket (alternative to R2; used when UPLOADS_DISK=uploads).
UPLOADS_S3_KEY=
UPLOADS_S3_SECRET=
UPLOADS_S3_REGION=us-east-1
UPLOADS_S3_BUCKET=
UPLOADS_S3_ENDPOINT=
UPLOADS_S3_PATH_STYLE=true

VITE_APP_NAME="${APP_NAME}"

# Stripe billing
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
# Optional. Leave blank to default to FRONTEND_URL + /billing/success|/billing/cancel.
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

# Web Push (VAPID). Generate a keypair with `php artisan push:vapid`, then put
# the PUBLIC key in the frontend too (NEXT_PUBLIC_VAPID_PUBLIC_KEY). Subject is a
# mailto: or https URL identifying the sender; defaults to APP_URL.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# AI data entry. Inference is routed through Cloudflare AI Gateway's REST API,
# so the app only needs the Cloudflare account id + an API token (provider keys
# are stored in the Cloudflare dashboard, BYOK). The gateway is named by header
# (defaults to "default"). The token also reads spend via the Gateway Logs API
# (needs "AI Gateway Read"); set CF_AI_GATEWAY_ANALYTICS_TOKEN to use a separate
# read-only token. AI is enabled/configured from the back office (/admin → AI).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CF_AIG_GATEWAY_ID=default
# CF_AI_GATEWAY_ANALYTICS_TOKEN=
# AI_ENABLED=false
# Per-capability model defaults ("provider/model"); overridable in the back office.
# AI_TEXT_MODEL=openai/gpt-4o-mini
# AI_VISION_MODEL=openai/gpt-4o-mini
