# Base URL of the Laravel API, including the /api/v1 prefix.
# This is the ONLY thing tying the frontend to the backend — change it and the
# whole app points somewhere else. That's what makes the frontend detachable.
NEXT_PUBLIC_API_URL=http://localhost/api/v1

# Optional display name shown in the UI shell.
NEXT_PUBLIC_APP_NAME=Terroir BI

# Web Push VAPID public key. Must match the backend's VAPID_PUBLIC_KEY (generate
# both with `php artisan push:vapid`). Leave empty to disable push in the UI.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=